# NASA Earthdata Login token (REQUIRED)
# Register at: https://urs.earthdata.nasa.gov/
EARTHDATA_TOKEN=your_earthdata_bearer_token_here

# Copernicus Climate Data Store API key (REQUIRED for cloud data)
# Register at: https://cds.climate.copernicus.eu/
CDS_API_KEY=your_cds_api_key_here

# AWS (for guide-api service only)
BUCKET_NAME=astrotraveler-guides
AWS_DEFAULT_REGION=eu-north-1

# TESS photometer data (OPTIONAL — for extended validation)
# Contact: rafael08@ucm.es or jzamorano@fis.ucm.es
IDA_URL=https://example.com/tess-ida-data/
